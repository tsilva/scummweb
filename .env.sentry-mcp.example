# Read-only Sentry access for Codex / MCP-style issue and event inspection.
# Keep the real file in `.env.sentry-mcp` and do not commit it.
#
# Required scopes for the token:
# - org:read
# - project:read
# - event:read
#
# The build plugin token in `.env.sentry-build-plugin` may not have these scopes.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=tsilva
SENTRY_PROJECT=scummweb
SENTRY_BASE_URL=https://sentry.io
