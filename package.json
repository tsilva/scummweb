{
  "name": "scummvm-web",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "preinstall": "node -e \"const ua = process.env.npm_config_user_agent || ''; if (!ua.startsWith('pnpm/')) { console.error('Use pnpm for this repo.'); process.exit(1); }\"",
    "prepare:scummvm-bundle": "./scripts/prepare_scummvm_bundle.sh",
    "archive:scummvm-bundle": "./scripts/archive_scummvm_bundle.sh",
    "predev": "pnpm run prepare:scummvm-bundle",
    "prebuild": "pnpm run prepare:scummvm-bundle",
    "prestart": "pnpm run prepare:scummvm-bundle",
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.46.0",
    "lucide-react": "^1.7.0",
    "next": "13.5.11",
    "playwright-core": "1.44.1",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
